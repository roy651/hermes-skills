TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_IDS=

# Vision LLM — any OpenAI-compatible endpoint with vision support
# Can be set to a stronger model than main Hermes for better OCR/map accuracy
VISION_API_URL=https://openrouter.ai/api/v1/chat/completions
VISION_API_KEY=
# VISION_MODEL sets a single model. VISION_MODELS (comma-separated) sets a priority list —
# free models are tried first, paid models act as fallback. If neither is set, defaults are used.
# VISION_MODELS=google/gemma-4-31b-it:free,google/gemma-4-26b-a4b-it:free,qwen/qwen3.5-flash-02-23,meta-llama/llama-3.2-11b-vision-instruct
VISION_MODEL=google/gemma-4-31b-it:free
